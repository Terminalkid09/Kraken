# ─────────────────────────────────────────────
# Kraken — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_super_secret_key_please_change_min_32_chars
INTERNAL_API_KEY=changeme_internal_api_key_please_change_min_32_chars

# Database (used by docker-compose automatically)
DATABASE_URL=postgresql+asyncpg://kraken:kraken_pass@kraken_db:5432/krakendb

# Redis
REDIS_URL=redis://kraken_redis:6379/0

# GeoIP — download GeoLite2-City.mmdb from https://dev.maxmind.com
# Place the file in ./data/ and set the path below
GEOIP_DB_PATH=/app/data/GeoLite2-City.mmdb

# Telegram Bot Alerts (optional)
# 1. Create a bot via @BotFather on Telegram
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Copy the chat_id from the response
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS — comma-separated list of allowed origins
# For production: set to your actual domain
CORS_ORIGINS=http://localhost:80

# Sensor ports (exposed by docker-compose)
SSH_SENSOR_PORT=2222
HTTP_SENSOR_PORT=8080
FTP_SENSOR_PORT=2121
TELNET_SENSOR_PORT=2323

# Sandbox
SANDBOX_IMAGE=kraken_sandbox
SANDBOX_MAX_LIFETIME=300
SANDBOX_NETWORK=kraken_sandbox_net
SANDBOX_MAX_CONCURRENT=20

# Rate limiting
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_INGEST=200/minute
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_EXPORT=30/minute

# Data directories
DATA_DIR=/app/data
MALWARE_DIR=/app/data/malware
LOGS_DIR=/app/data/logs

# Sandbox API (sensors use this instead of Docker socket)
SANDBOX_API_URL=http://kraken_app:8000/api/v1/containers

# Security
BCRYPT_ROUNDS=12
MAX_BODY_SIZE=65536
