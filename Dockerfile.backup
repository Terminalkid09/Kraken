FROM alpine:3.19

RUN apk add --no-cache \
    postgresql-client \
    redis \
    bash \
    gzip \
    tar \
    dcron \
    curl

COPY scripts/backup.sh /usr/local/bin/backup.sh
COPY scripts/restore.sh /usr/local/bin/restore.sh

RUN chmod +x /usr/local/bin/backup.sh /usr/local/bin/restore.sh

# Create backup directories
RUN mkdir -p /backups /var/log && \
    adduser -D -h /backups backup && \
    chown -R backup:backup /backups

# Install crontab as root, run cron as daemon
COPY <<'CRON' /etc/crontabs/root
0 2 * * * /usr/local/bin/backup.sh >> /var/log/backup.log 2>&1
CRON

CMD ["/bin/bash", "-c", "crond -f -l 2 & exec tail -f /dev/null"]
